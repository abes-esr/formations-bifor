        <managed-bean-scope>request</managed-bean-scope>        
    </managed-bean>
    
    
    <navigation-rule>
        <from-view-id>/liste-sessions.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>show</from-outcome>
            <to-view-id>/liste-inscriptions.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>success</from-outcome>
            <to-view-id>/liste-sessions.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>formateur</from-outcome>
            <to-view-id>/liste-formateurs.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>lieu</from-outcome>
            <to-view-id>/liste-lieux.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>new</from-outcome>
            <to-view-id>/edit-sessions.xhtml</to-view-id>

        </navigation-case>
        <navigation-case>
            <from-outcome>refresh</from-outcome>
            <to-view-id>/liste-sessions.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <from-view-id>/liste-inscriptions.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>back</from-outcome>
            <to-view-id>/liste-sessions.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>success</from-outcome>
            <to-view-id>/liste-inscriptions.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>edit</from-outcome>
            <to-view-id>/edit-inscription.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>confirm</from-outcome>
            <to-view-id>/confirm-inscription.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>error</from-outcome>
            <to-view-id>/liste-inscriptions.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <from-view-id>/edit-inscription.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>back</from-outcome>
            <to-view-id>/liste-inscriptions.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>success</from-outcome>
            <to-view-id>/liste-inscriptions.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <from-view-id>/confirm-inscription.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>success</from-outcome>
            <to-view-id>/liste-inscriptions.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>back</from-outcome>
            <to-view-id>/liste-inscriptions.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>error</from-outcome>
            <to-view-id>/confirm-inscription.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <from-view-id>/edit-sessions.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>error</from-outcome>
            <to-view-id>/edit-sessions.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>back</from-outcome>
            <to-view-id>/liste-session.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>success</from-outcome>
            <to-view-id>/liste-session.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <from-view-id>/liste-formateurs.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>show</from-outcome>
            <to-view-id>/edit-formateur.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>new</from-outcome>
