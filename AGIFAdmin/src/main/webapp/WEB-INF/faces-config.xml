    <managed-bean>
        <description>Le service métier</description>
        <managed-bean-name>agifManageService</managed-bean-name>
        <managed-bean-class>org.formation.service.impl.AgifManageServiceImpl</managed-bean-class>
        <managed-bean-scope>application</managed-bean-scope>
