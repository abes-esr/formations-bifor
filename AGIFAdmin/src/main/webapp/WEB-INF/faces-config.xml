        <managed-bean-name>agifDocument</managed-bean-name>
        <managed-bean-class>org.formation.writer.impl.AgifWriterImpl</managed-bean-class>
        <managed-bean-scope>application</managed-bean-scope>
    </managed-bean>

   <managed-bean>
        <description>Le bean d'accueil</description>
        <managed-bean-name>indexBean</managed-bean-name>
        <managed-bean-class>org.formation.web.IndexBean</managed-bean-class>
        <managed-bean-scope>request</managed-bean-scope>       
    </managed-bean>
    
    <managed-bean>
        <description>Le bean de la liste des sessions</description>
        <managed-bean-name>listSessionsBean</managed-bean-name>
        <managed-bean-class>org.formation.web.ListSessionsBean</managed-bean-class>
        <managed-bean-scope>session</managed-bean-scope>
        <managed-property>
            <property-name>service</property-name>
            <value>#{agifManageService}</value>
        </managed-property>
    </managed-bean>
   
    

    <managed-bean>
        <description>Le bean de la liste des inscriptions</description>
