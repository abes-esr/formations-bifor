<?xml version='1.0' encoding='UTF-8'?>

<!-- =========== FULL CONFIGURATION FILE ================================== -->

<faces-config version="2.1" 
              xmlns="http://java.sun.com/xml/ns/javaee"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://java.sun.com/xml/ns/javaee http://java.sun.com/xml/ns/javaee/web-facesconfig_2_1.xsd">
    <application>
        <locale-config>
            <default-locale>fr</default-locale>
            <supported-locale>en</supported-locale>
        </locale-config>
        <message-bundle>org.formation.ressources.MessagesValidation</message-bundle>
        <resource-bundle>
            <base-name>org.formation.ressources.MessagesLibelles</base-name>
            <var>lang</var>
        </resource-bundle>
    </application>
    <validator>
        <validator-id>fieldValidator</validator-id>
        <validator-class>org.formation.web.FieldValidator</validator-class>
    </validator>
    <managed-bean>
        <description>Le service métier</description>
        <managed-bean-name>agifService</managed-bean-name>
        <managed-bean-class>org.formation.service.impl.AgifServiceImpl</managed-bean-class>
        <managed-bean-scope>application</managed-bean-scope>
    </managed-bean>

    <managed-bean>
        <description>Le bean d'acces direct aux formations</description>
        <managed-bean-name>indexBeanInscription</managed-bean-name>
        <managed-bean-class>org.formation.web.IndexBeanInscription</managed-bean-class>
        <managed-bean-scope>request</managed-bean-scope>       
    </managed-bean>
    
    <managed-bean>
        <description>Le bean d'acces direct a la connexion</description>
        <managed-bean-name>indexBeanConnnexion</managed-bean-name>
        <managed-bean-class>org.formation.web.IndexBeanConnexion</managed-bean-class>
        <managed-bean-scope>request</managed-bean-scope>       
    </managed-bean>
    <managed-bean>
        <description>Le bean d'affichage du css de la page</description>
        <managed-bean-name>templateBean</managed-bean-name>
        <managed-bean-class>org.formation.web.TemplateBean</managed-bean-class>
        <managed-bean-scope>request</managed-bean-scope>        
    </managed-bean>
   
    <converter>
        <converter-for-class>org.formation.model.Sessions</converter-for-class>
        <converter-class>org.formation.web.components.SessionsConverter</converter-class>
    </converter>
    <converter>
        <converter-for-class>org.formation.model.Etablissement</converter-for-class>
        <converter-class>org.formation.web.components.EtablissementConverter</converter-class>
    </converter>
    <navigation-rule>
        <from-view-id>/liste-formations.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>success</from-outcome>
            <to-view-id>/inscription-sessions.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <from-view-id>/inscription-sessions.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>register</from-outcome>
            <to-view-id>/inscription-stagiaire.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>back</from-outcome>
            <to-view-id>/liste-formations.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <from-view-id>/inscription-stagiaire.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>back</from-outcome>
            <to-view-id>/inscription-sessions.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>success</from-outcome>
            <to-view-id>/inscription-questions.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>failure</from-outcome>
            <to-view-id>/inscription-stagiaire.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>validation</from-outcome>
            <to-view-id>/inscription-validation.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <from-view-id>/inscription-validation.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>back_stagiaire</from-outcome>
            <to-view-id>/inscription-stagiaire.xhtml</to-view-id>
            <redirect/>
        </navigation-case>
        <navigation-case>
            <from-outcome>back_sessions</from-outcome>
            <to-view-id>/inscription-sessions.xhtml</to-view-id>
            <redirect/>
        </navigation-case>
        <navigation-case>
            <from-outcome>back_questions</from-outcome>
            <to-view-id>/inscription-questions.xhtml</to-view-id>
            <redirect/>
        </navigation-case>
        <navigation-case>
            <from-outcome>success</from-outcome>
            <to-view-id>/inscription-ok.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>failure</from-outcome>
            <to-view-id>/inscription-nok.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>back</from-outcome>
            <to-view-id>/liste-formations.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <from-view-id>/inscription-questions.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>success</from-outcome>
            <to-view-id>/inscription-validation.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>back</from-outcome>
            <to-view-id>/inscription-stagiaire.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <from-view-id>/inscription-ok.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>back</from-outcome>
            <to-view-id>/liste-formations.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <from-view-id>/inscription-nok.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>back</from-outcome>
            <to-view-id>/liste-formations.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <from-view-id>/connexion-stagiaire.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>register</from-outcome>
            <to-view-id>/inscription-stagiaire.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>success</from-outcome>
            <to-view-id>/inscription-questions.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>failure</from-outcome>
            <to-view-id>/connexion-stagiaire.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>back</from-outcome>
            <to-view-id>/inscription-sessions.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>forgot</from-outcome>
            <to-view-id>/oublie-motdepasse.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <from-view-id>/oublie-motdepasse.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>failure</from-outcome>
            <to-view-id>/oublie-motdepasse.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>success</from-outcome>
            <to-view-id>/motdepasse-retrouve.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>back</from-outcome>
            <to-view-id>/connexion-stagiaire.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <from-view-id>/motdepasse-retrouve.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>login</from-outcome>
            <to-view-id>/connexion-stagiaire.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <from-view-id>/demande-formation.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>success</from-outcome>
            <to-view-id>/inscription-sessions.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>error</from-outcome>
            <to-view-id>/erreur.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <from-view-id>/moncompte-connexion.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>forgot</from-outcome>
            <to-view-id>/moncompte-oublie-motdepasse.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>success</from-outcome>
            <to-view-id>/moncompte-liste-inscriptions.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>failure</from-outcome>
            <to-view-id>/moncompte-connexion.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <from-view-id>/moncompte-oublie-motdepasse.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>back</from-outcome>
            <to-view-id>/moncompte-connexion.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>success</from-outcome>
            <to-view-id>/moncompte-motdepasse-retrouve.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <from-view-id>/moncompte-motdepasse-retrouve.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>login</from-outcome>
            <to-view-id>/moncompte-connexion.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <from-view-id>/moncompte-liste-inscriptions.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>edit-id</from-outcome>
            <to-view-id>/moncompte-edit-identifiants.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>edit</from-outcome>
            <to-view-id>/moncompte-edit-stagiaire.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>logout</from-outcome>
            <to-view-id>/moncompte-connexion.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <from-view-id>/moncompte-edit-identifiants.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>success</from-outcome>
            <to-view-id>/moncompte-liste-inscriptions.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>failure</from-outcome>
            <to-view-id>/moncompte-liste-inscriptions.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>back</from-outcome>
            <to-view-id>/moncompte-liste-inscriptions.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>logout</from-outcome>
            <to-view-id>/moncompte-connexion.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>edit</from-outcome>
            <to-view-id>/moncompte-edit-stagiaire.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>list</from-outcome>
            <to-view-id>/moncompte-liste-inscriptions.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <from-view-id>/moncompte-edit-stagiaire.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>success</from-outcome>
            <to-view-id>/moncompte-liste-inscriptions.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>failure</from-outcome>
            <to-view-id>/moncompte-liste-inscriptions.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>back</from-outcome>
            <to-view-id>/moncompte-liste-inscriptions.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>logout</from-outcome>
            <to-view-id>/moncompte-connexion.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>edit-id</from-outcome>
            <to-view-id>/moncompte-edit-identifiants.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>list</from-outcome>
            <to-view-id>/moncompte-liste-inscriptions.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
    
    
    <navigation-rule>
        <from-view-id>/formateur-liste-sessions.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>show</from-outcome>
            <to-view-id>/formateur-liste-inscriptions.xhtml</to-view-id>
        </navigation-case>
        <navigation-case>
            <from-outcome>refresh</from-outcome>
            <to-view-id>/formateur-liste-sessions.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
    <navigation-rule>
        <from-view-id>/formateur-liste-inscriptions.xhtml</from-view-id>
        <navigation-case>
            <from-outcome>back</from-outcome>
            <to-view-id>/formateur-liste-sessions.xhtml</to-view-id>
        </navigation-case>
    </navigation-rule>
</faces-config>


