<?xml version="1.0" encoding="UTF-8"?>
<Context antiJARLocking="true" path="/AGIFWeb">
 <!-- Specify a JDBC datasource -->
   <Resource name="jdbc/AGIFDataSource"
   auth="Container"
   description="Oracle demande de formation database"
   type="oracle.jdbc.pool.OracleDataSource"
   driverClassName="oracle.jdbc.driver.OracleDriver"
   factory="oracle.jdbc.pool.OracleDataSourceFactory"
   url="${sql.url.prod}/ABES"
   maxActive="8"
   maxIdle="8"
   minIdle="0"
   maxWait="5000" />
 <Resource name="jdbc/BaseCBS"
   auth="Container"
   description="base XML APISUDOC CBS"
   type="oracle.jdbc.pool.OracleDataSource"
   driverClassName="oracle.jdbc.driver.OracleDriver"
   factory="oracle.jdbc.pool.OracleDataSourceFactory"
   url="${sql.url.prod}/APISUDOC"
   maxActive="8"
   maxIdle="8"
   minIdle="0"
   maxWait="5000" />
    <Resource name="jdbc/SybaseCBS"
   auth="Container"
   description="Sybase CBS BackOffice (users, ILN, RCRs...)"
   type="javax.sql.DataSource"
   driverClassName="net.sourceforge.jtds.jdbc.Driver"
   url="jdbc:jtds:sybase://${cbs.backoffice.url}"
   maxActive="8"
   maxIdle="8"
   minIdle="0"
   maxWait="5000" />

   
</Context>